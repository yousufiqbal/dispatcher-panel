# Required — your PostgreSQL connection string
DATABASE_URL="postgres://user:password@localhost:5432/dispatcher_panel"

# Required — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="change_this_to_a_random_64_char_hex_string"
ENCRYPTION_KEY="change_this_to_a_random_64_char_hex_string"

# Optional
PUBLIC_APP_NAME="Dispatcher Panel"
NODE_ENV="development"

# For seeding the admin account (npm run seed)
ADMIN_EMAIL="admin@yourdomain.com"
ADMIN_PASSWORD="your-strong-admin-password"
