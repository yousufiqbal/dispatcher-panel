# Required — your Turso (libSQL) database URL + auth token
DATABASE_URL="libsql://your-database.turso.io"
DATABASE_AUTH_TOKEN="your-turso-auth-token"

# Required — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="change_this_to_a_random_64_char_hex_string"
ENCRYPTION_KEY="change_this_to_a_random_64_char_hex_string"

# Note: there's no admin-seeding step — visiting /login with no admin account
# yet in the database shows a one-time "set up admin account" form instead.

# Web Push (order notifications) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY="change_this"
PUBLIC_VAPID_KEY="same_value_as_VAPID_PUBLIC_KEY"
VAPID_PRIVATE_KEY="change_this"
VAPID_SUBJECT="mailto:you@yourdomain.com"

# Base URL used to register Shopify webhooks (must be a public HTTPS URL)
PUBLIC_APP_URL="https://yourapp.example.com"

# Secret required to call /api/cron/sync-bookings (courier tracking status sync).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Point an external cron (Vercel Cron, cron-job.org, etc.) at that URL every 15-30 min
# with header "x-cron-secret: <this value>" or query param ?secret=<this value>.
CRON_SECRET="change_this_to_a_random_64_char_hex_string"
